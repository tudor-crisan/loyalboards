{
  "paths": {
    "signin": {
      "source": "/auth/signin",
      "destination": "/modules/auth/signin"
    },
    "signout": {
      "source": "/auth/signout",
      "destination": "/modules/auth/signout"
    },
    "error": {
      "source": "/auth/error",
      "destination": "/modules/auth/error"
    },
    "verifyRequest": {
      "source": "/auth/verify-request",
      "destination": "/modules/auth/verify-request"
    },
    "nextAuthApi": {
      "source": "/api/auth/:path*",
      "destination": "/api/modules/auth/:path*"
    },
    "userUpdate": {
      "source": "/api/user/update",
      "destination": "/api/modules/user/update"
    },
    "dashboard": {
      "source": "/dashboard",
      "destination": "/modules/dashboard"
    },
    "billingCreateCheckout": {
      "source": "/api/billing/create-checkout",
      "destination": "/api/modules/billing/create-checkout"
    },
    "billingCreatePortal": {
      "source": "/api/billing/create-portal",
      "destination": "/api/modules/billing/create-portal"
    },
    "billingWebhook": {
      "source": "/api/billing/webhook",
      "destination": "/api/modules/billing/webhook"
    },
    "billingSuccess": {
      "source": "/success",
      "destination": "/modules/billing/success"
    }
  },
  "auth": {
    "providers": ["resend", "google"],
    "hasThemePages": true,
    "hasThemeEmails": true
  },
  "rateLimits": {
    "auth-quick-link": {
      "limit": 5,
      "window": 300
    },
    "auth-google-signin": {
      "limit": 10,
      "window": 60
    },
    "resend-test-email": {
      "limit": 5,
      "window": 60
    }
  },
  "metadata": {
    "auth": {
      "title": "Authenticate - {appName}",
      "description": "{seoTagline}"
    }
  }
}
